# =============================================================================
# .gitignore for grave_d_data2026
# R / RStudio / Quarto data pipeline project
# GRAVE-D Master Dyadic Dataset Builder
# =============================================================================

# -------------------------------------------------------------------------
# DATA -- never commit raw source data or derived output
# -------------------------------------------------------------------------
source_data/

# -------------------------------------------------------------------------
# INTERMEDIATE OUTPUT -- data/ holds .rds intermediates; never commit
# -------------------------------------------------------------------------
data/
!data/.gitkeep

# -------------------------------------------------------------------------
# DATA FILE FORMATS -- catch any stray data files at repo root
# -------------------------------------------------------------------------
*.csv
*.dta
*.sav
*.xlsx
*.xls
*.rds
*.RData
*.feather
*.parquet

# -------------------------------------------------------------------------
# Exceptions: keep placeholder/gitkeep files so folders exist in repo
# -------------------------------------------------------------------------
!source_data/.gitkeep
!source_data/fbic/.gitkeep
!source_data/cow/.gitkeep
!source_data/colgan/.gitkeep
!source_data/archigos/.gitkeep
!source_data/leader_ideology/.gitkeep
!source_data/atop/.gitkeep
!source_data/econ/.gitkeep
!source_data/econ/fraser_institute/.gitkeep
!source_data/econ/maddison/.gitkeep
!source_data/econ/relational_export_dataset/.gitkeep
!source_data/econ/ross_oil_gas/.gitkeep
!source_data/econ/swiid/.gitkeep
!source_data/econ/codebooks/.gitkeep
!source_data/controls/.gitkeep
!source_data/controls/cinc/.gitkeep
!source_data/controls/state_capacity/.gitkeep
!source_data/vdem/.gitkeep

# -------------------------------------------------------------------------
# READY_DATA -- allow final CSV exports to be committed
# -------------------------------------------------------------------------
!ready_data/
!ready_data/.gitkeep
!ready_data/*.csv

# -------------------------------------------------------------------------
# R-specific
# -------------------------------------------------------------------------
.Rhistory
.RData
.Rapp.history
.Rproj.user/
*.Rproj.user

# R package library (if using renv)
renv/library/
renv/.cache/
packrat/lib/
packrat/lib-ext/
packrat/lib-R/
packrat/src/

# -------------------------------------------------------------------------
# Quarto / knitr
# -------------------------------------------------------------------------
/_site/
/_book/
*_cache/
*_files/
*.html
!README.html

# -------------------------------------------------------------------------
# OS junk
# -------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
